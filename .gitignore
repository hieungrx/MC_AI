# Python caches
__pycache__/
*.py[cod]
*$py.class

# Environments
.venv/
venv/
ENV/
env/

# Project Logs
logs/
*.log

# Operating System Files
.DS_Store
Thumbs.db

# Output directory caches (generated audio/video)
assets/audio/*
assets/video/*
!assets/audio/.gitkeep
!assets/video/.gitkeep

# IDE specific files
.vscode/
.idea/

# Local custom configs
configs/local.yaml
